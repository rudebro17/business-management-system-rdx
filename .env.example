# Backend environment variables
# Copy this to .env.local for local development

# Local dev: path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./businessmanr-console-rdx-firebase-adminsdk-fbsvc-76263ae8cc.json

# Production (Render): paste the entire JSON content of your service account as a one-liner
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# JWT secret - use any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Production only: your Vercel frontend URL (no trailing slash)
# FRONTEND_URL=https://your-app.vercel.app
